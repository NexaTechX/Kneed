# Copy to .env and fill in values from the Supabase project dashboard (Settings → API).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: EAS project ID for Expo push tokens (expo.dev → project → Project ID).
# Add under app.json → expo.extra.eas.projectId, or Expo may prompt during `eas build`.

# Paystack: set PAYSTACK_SECRET_KEY in Supabase Edge Function secrets (not in the app).
# Deploy: supabase functions deploy paystack-initialize paystack-webhook
# Webhook URL: https://YOUR_PROJECT.supabase.co/functions/v1/paystack-webhook
# Register that URL in the Paystack dashboard.
